<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:res="clr-namespace:NEKODORO.Resources"
             x:Class="NEKODORO.TimerPage"
             BackgroundColor="#2C3E50"
             Shell.NavBarIsVisible="False">

    <VerticalStackLayout Spacing="25" VerticalOptions="Center" Padding="30">

        <Image x:Name="StudyBunny" 
               Source="bunnyrun.gif" 
               IsAnimationPlaying="True"
               HeightRequest="200" />

        <Label x:Name="TimerLabel"
               Text="25:00"
               FontSize="80"
               TextColor="White"
               HorizontalOptions="Center"
               FontAttributes="Bold" />

        <Label x:Name="StatusLabel"
               Text="{x:Static res:AppResources.FocusTimeStatus}"
               TextColor="#ECF0F1"
               HorizontalOptions="Center" />

        <Button Text="{x:Static res:AppResources.QuitBtn}"
                Clicked="OnQuitClicked"
                BackgroundColor="#E74C3C"
                CornerRadius="20"
                WidthRequest="150" />
    </VerticalStackLayout>
</ContentPage>